# TallyAI Connector — Environment Configuration
# Copy this file to .env and fill in your values

# URL of your deployed TallyAI platform
PLATFORM_URL=https://your-app.railway.app

# Sync token from Settings → Connector in the TallyAI dashboard
SYNC_TOKEN=your-sync-token-here

# How often to sync (in minutes). Minimum 5 (platform rate limit is 5 min)
SYNC_INTERVAL_MINUTES=15

# Tally Prime XML server URL (default: http://localhost:9000)
# Only change this if you changed the Tally XML server port
TALLY_URL=http://localhost:9000
