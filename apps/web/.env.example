# TallyAI Web — Environment Variables
# Copy to .env.local for local development

# PostgreSQL connection string
# Railway provides this automatically as ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@localhost:5432/tallyai

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-character-random-secret-here

# Your app's public URL (set automatically on Railway)
# For local dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
